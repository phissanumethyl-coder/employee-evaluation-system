rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /employees/{empId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.branchId is string
        && request.resource.data.name is string
        && request.resource.data.status in ['probation','passed','terminated'];
      allow update: if signedIn();
      allow delete: if false;
    }

    match /evaluations/{evalId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.branchId is string
        && request.resource.data.verdict in ['pass','fail'];
      // อนุญาตให้อัปเดตได้เฉพาะ field hrHandled เท่านั้น (กันแก้ผลประเมิน)
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hrHandled']);
      allow delete: if false;
    }
  }
}
